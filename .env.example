# === 通义千问 Qwen ===
# DashScope API 密钥（必填）：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
# 模型名，默认 qwen-plus，可选 qwen-max
QWEN_MODEL=qwen-plus

# === 抓取 ===
# 每个来源抓取的条数，默认 10
ITEMS_PER_SOURCE=10
# AI 相关性初筛关键词，逗号分隔（留空用内置默认值）
# AI_KEYWORDS=ai,llm,gpt,agent,model
# RSS 源列表，逗号分隔（留空用内置默认值）
# RSS_FEEDS=https://openai.com/news/rss.xml,https://www.anthropic.com/rss.xml

# === 邮件 SMTP（必填）===
# 以 QQ 邮箱为例：SMTP_HOST=smtp.qq.com  SMTP_PORT=465
# SMTP_PASS 通常是邮箱的“授权码/应用专用密码”，不是登录密码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_account@qq.com
SMTP_PASS=your_smtp_auth_code
MAIL_FROM=your_account@qq.com
MAIL_TO=recipient@example.com
